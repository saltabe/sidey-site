---
import { type CollectionEntry, render } from "astro:content"

import SinglePage from "@layouts/pages/SinglePage.astro"
import SubscribePage from "@layouts/pages/SubscribePage.astro"
import ContactPage from "@layouts/pages/ContactPage.astro"
import { getPages } from "@utils/getContent"

export async function getStaticPaths() {
  const pages = getPages()

  return (await pages).map((page) => ({
    params: { id: page.id === "home" ? undefined : page.id },
    props: { page },
  }))
}

interface Props {
  page: CollectionEntry<"pages">
}

const { page } = Astro.props
const { Content } = await render(page)
let PageTemplate = null

switch(page.id) {
  case "contact":
    PageTemplate = ContactPage
    break
  case "subscribe":
    PageTemplate = SubscribePage
    break
  default:
    PageTemplate = SinglePage
}
---

<PageTemplate frontmatter={page}>
  <Content />
</PageTemplate>
