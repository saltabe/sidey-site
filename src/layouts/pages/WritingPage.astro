---
import BaseLayout from "@layouts/BaseLayout.astro"
import Prose from "@components/common/Prose.astro"
import PostTags from "@components/common/PostTags.astro"
import Back from "@components/common/Back.astro"
import { formatDate } from "@utils/formatDate"

const { frontmatter, readingTime } = Astro.props
const { title, description, date, tags } = frontmatter.data

const formattedDate = formatDate(date, "long")
---

<BaseLayout title={title} description={description}>
  <Prose>
    <h1>{title}</h1>

    <div class="-mt-4 mb-8 space-x-2 text-sm text-muted-foreground">
      <time datetime={date}>{formattedDate}</time>
      <span>&middot;</span>
      <span>{readingTime}</span>
    </div>

    <slot />

    <Back label="Back to Writings" href="/writings" class="mt-8" />

    <br />
    <br />
    <form action="https://formsubmit.co/savannah@savannahaltabe.com" method="POST" />
    <input type="text" name="name" placeholder="Name" required />
    
    <br />
    <input type="email" name="email" inputmode="email" placeholder="Email Address" required />
  
    <br />
    <textarea name="comment" rows="4" placeholder="Comment" required></textarea>
    
    <input type="hidden" name="form_location" value="page-title-input">

    <br />
    <button type="submit">Submit</button>
    </form>

  </Prose>
</BaseLayout>
