---
import BaseLayout from "@layouts/BaseLayout.astro"
import Prose from "@components/common/Prose.astro"
import PostTags from "@components/common/PostTags.astro"
import Back from "@components/common/Back.astro"
import { formatDate } from "@utils/formatDate"

const { frontmatter, readingTime } = Astro.props
const { title, description, date, tags } = frontmatter.data

const formattedDate = formatDate(date, "long")
---

<BaseLayout title={title} description={description}>
  <Prose>
    <h1>{title}</h1>

    <div class="-mt-4 mb-8 space-x-2 text-sm text-muted-foreground">
      <time datetime={date}>{formattedDate}</time>
      <span>&middot;</span>
      <span>{readingTime}</span>
    </div>

    <slot />

    <Back label="Back to Writings" href="/writings" class="mt-8" />

    <br />
    <br />
    <div class="comment-container">
    <h2>Leave a Comment</h2>
    
    <form action="/submit-comment" method="POST">
        
        <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" placeholder="Name" required>
        </div>

        <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="Email address" required>
        </div>

        <div class="form-group">
            <label for="comment">Comment</label>
            <textarea id="comment" name="comment" placeholder="Comment" required></textarea>
        </div>

        <button type="submit" class="submit-btn">Submit</button>
        
    </form>
  
  
  </div>

  </Prose>
</BaseLayout>
